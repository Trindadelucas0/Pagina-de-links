<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Paulo Dias - Contador | Êxito Contabilidade - Links oficiais">
  <meta name="author" content="Paulo Dias">
  <title>Paulo Dias | Êxito Contabilidade</title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Font Awesome Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <!-- Custom Styles -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Main Container -->
  <div class="container">
    <div class="card">

      <!-- Theme Toggle -->
      <div class="theme-toggle">
        <button class="toggle-btn" id="theme-toggle" aria-label="Alternar tema claro/escuro">
          <i class="fas fa-moon"></i>
          <span class="toggle-track">
            <span class="toggle-thumb"></span>
          </span>
          <i class="fas fa-sun"></i>
        </button>
      </div>

      <!-- Profile Section -->
      <div class="profile fade-in">
        <div class="profile-photo-wrapper">
          <img
            src="<%= profile.photo %>"
            alt="<%= profile.photoAlt %>"
            class="profile-photo"
            id="profile-img"
          >
        </div>
        <h1 class="profile-name"><%= profile.name %></h1>
        <span class="profile-username">
          <%= profile.username %> <i class="<%= profile.usernameIcon %>"></i>
        </span>
      </div>

      <!-- Links -->
      <div class="links">
        <% links.forEach(function(link) { %>
        <a
          href="<%= link.href %>"
          target="_blank"
          rel="noopener noreferrer"
          class="link-btn fade-in-link"
          id="<%= link.id %>"
        >
          <i class="<%= link.icon %>"></i>
          <%= link.label %>
        </a>
        <% }); %>
      </div>

      <!-- Social Icons -->
      <div class="social-icons fade-in">
        <% socialLinks.forEach(function(social) { %>
        <a
          href="<%= social.href %>"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon"
          aria-label="<%= social.label %>"
          id="<%= social.id %>"
        >
          <i class="<%= social.icon %>"></i>
        </a>
        <% }); %>
      </div>

      <!-- Footer -->
      <div class="footer fade-in">
        <p>
          © Êxito Contabilidade
          <i class="fas fa-link" style="font-size: 0.65rem; color: var(--blue-accent);"></i>
        </p>
      </div>

    </div>
  </div>

  <!-- JavaScript -->
  <script src="/js/script.js"></script>
</body>
</html>
